# ==============================================================================
# Database Configuration
# ==============================================================================
DB_NAME=cloud_storage_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://redis:6379/1

# ==============================================================================
# MinIO / S3 Configuration
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_root_password_here

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=your_minio_root_password_here
AWS_STORAGE_BUCKET_NAME=user-files
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_USE_SSL=False
AWS_DEFAULT_ACL=None
AWS_S3_VERIFY=False

# ==============================================================================
# Django Settings
# ==============================================================================
DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8000